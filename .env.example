APP_NAME=Earthquake Event Platform
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=true
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=earthquake_platform
MONGODB_EARTHQUAKES_COLLECTION=earthquakes
MONGODB_HOURLY_METRICS_COLLECTION=hourly_metrics
MONGODB_HOURLY_REPORTS_COLLECTION=hourly_reports
USGS_BASE_URL=https://earthquake.usgs.gov
USGS_SUMMARY_PATH=/earthquakes/feed/v1.0/summary/all_hour.geojson
REQUEST_TIMEOUT_SECONDS=10
INGESTION_INTERVAL_SECONDS=180
MONGODB_PORT=27017
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_UID=50000
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
